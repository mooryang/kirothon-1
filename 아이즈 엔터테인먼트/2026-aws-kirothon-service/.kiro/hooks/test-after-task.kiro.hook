{
  "enabled": true,
  "name": "태스크 완료 후 테스트",
  "description": "spec 태스크 완료 후 자동으로 테스트를 실행하여 구현이 올바른지 검증한다.",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "npx vitest run --reporter=verbose 2>&1 | tail -30",
    "timeout": 60
  }
}